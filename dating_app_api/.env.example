PORT=3000
NODE_ENV=development
JWT_SECRET=please_set_a_strong_secret

# Database (Prisma)
DATABASE_URL=mysql://user:password@host:3306/database

# CORS
CORS_ENABLED=true
ALLOWED_ORIGINS=*

# Upstash Redis (optional)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# CloudBase (optional)
CLOUDBASE_ENV_ID=
CLOUDBASE_STORAGE_URL=

# Tencent IM (optional)
TENCENT_IM_SDK_APP_ID=
TENCENT_IM_SECRET=

# JPush (optional)
JPUSH_APP_KEY=
JPUSH_MASTER_SECRET=
